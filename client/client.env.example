# Local SPA env (loaded by Vite via vite.config.ts — see dotenv + loadEnv).
# Copy this file to `client/client.env` and fill in your values.
# `client.env` is gitignored and must not be committed.

# Azure AD SPA registration — same tenant + app id as the server's AZURE_AD_* vars.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=

# Vite dev proxy target — must match server PORT in server/server.env (default API port is 3002).
VITE_DEV_API_PORT=3002

# Production / remote API (leave unset in local dev to use same-origin + proxy).
# VITE_API_URL=https://your-api.example.com
