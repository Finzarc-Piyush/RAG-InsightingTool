# Local SPA env (loaded by Vite via vite.config — see dotenv + loadEnv).
# Copy to this file from team template; do not commit secrets you care about if the repo is shared.

VITE_AZURE_CLIENT_ID=1e24c2a8-9e7c-4935-9806-de3c0f2457c5
VITE_AZURE_TENANT_ID=5980857f-f17e-414f-aab2-43ccb50d9d14

# Vite dev proxy target — must match server PORT in server/server.env (default API port is 3003).
VITE_DEV_API_PORT=3002

# Production / remote API (leave unset in local dev to use same-origin + proxy).
# VITE_API_URL=https://your-api.example.com
