# Copy relevant lines into `server.env` in this directory (see loadEnv.ts). Do not commit real secrets.

# HTTP port for the API (default 3002). If you change it, set the same port in client/client.env as VITE_DEV_API_PORT
# or VITE_DEV_API_ORIGIN so Vite’s /api proxy still reaches the server.

# Azure AD JWT validation (same tenant + app id as VITE_AZURE_* in client/client.env)
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=

# Local Python data-ops service
# PYTHON_SERVICE_URL=http://localhost:8001

# Initial upload: dataset profile LLM + session context seed LLM on sample/summary (no upload-time charts/insights).
# DATASET_PROFILE_TIMEOUT_MS=45000

# Skip upload-time LLM (profile + session context seed); enrichment still marked complete so chat is not blocked.
# DISABLE_UPLOAD_INITIAL_ANALYSIS=false

# RAG — create index first: npm run create-rag-index
# Smoke check: npm run rag-smoke  (optional: RAG_SMOKE_SESSION_ID=... RAG_SMOKE_QUERY=...)
# When AGENTIC_LOOP_ENABLED=true, RAG is required: RAG_ENABLED=true plus the AZURE_SEARCH_* vars below, and
# AZURE_OPENAI_EMBEDDING_DIMENSIONS must match your Search index vector size.
# RAG_ENABLED=false
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_ADMIN_KEY=
# AZURE_SEARCH_INDEX_NAME=rag-session-chunks
# AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072
# RAG_TOP_K=8

# Agent loop (structured working memory + dependsOn step ordering — see lib/agents/runtime/workingMemory.ts)
# AGENTIC_LOOP_ENABLED=false
# With AGENTIC_LOOP_ENABLED=true: no legacy orchestrator / monolithic dataAnalyzer fallback; RAG must be enabled (see above).
# Tests only — do not use in production: allows starting the server with agentic on but RAG disabled (mock retrieval in tests).
# AGENTIC_ALLOW_NO_RAG=false
# Deprecated when agentic is on (strict failure paths are always used): AGENTIC_STRICT
# AGENTIC_STRICT=false
# AGENT_MAX_STEPS=12
# AGENT_MAX_TOOL_CALLS=20
# Extra charts proposed by LLM after tool observations (0–2). Set 0 to disable.
# AGENT_MAX_EXTRA_CHARTS_PER_TURN=2
# Persist rolling sessionAnalysisContext during the agent turn (throttled). Set false to disable mid-turn merges.
# AGENT_MID_TURN_CONTEXT=true
# AGENT_MID_TURN_CONTEXT_THROTTLE_MS=8000
# Drop a second intermediate pivot SSE when it is a ≤1-row preview after a richer multi-row intermediate in the same turn.
# AGENT_INTERMEDIATE_PIVOT_COALESCE=true
# Persist structured Planner / Verifier / Reflector handoffs on AgentTrace.interAgentMessages (debug / multi-agent groundwork).
# AGENT_INTER_AGENT_MESSAGES=false
# When true with AGENT_INTER_AGENT_MESSAGES, append a compact handoff digest to planner + reflector prompts (replan quality; uses more tokens).
# AGENT_INTER_AGENT_PROMPT_FEEDBACK=false

# Diagnostic (“deep dive”) pipeline — off by default; enable after validating golden tests.
# Merge parseUserQuery dimensionFilters into intermediate SSE pivot hints (diagnostic questions + parser confidence).
# DIAGNOSTIC_PIVOT_FILTER_MERGE_ENABLED=false
# Minimum parser confidence (0–1) for that merge.
# DIAGNOSTIC_PIVOT_MERGE_MIN_CONFIDENCE=0.75
# Row cap for diagnostic slices / correlation on turn-start data.
# DIAGNOSTIC_SLICE_ROW_CAP=100000
# Max parallel branches inside run_segment_driver_analysis.
# DIAGNOSTIC_MAX_PARALLEL=3
# Registers run_segment_driver_analysis agent tool (one-shot segment drivers).
# DIAGNOSTIC_COMPOSITE_TOOL_ENABLED=false
