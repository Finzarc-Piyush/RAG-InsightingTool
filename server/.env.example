# Copy relevant lines into `server/server.env` (loaded by loadEnv.ts).
# Do not commit real secrets. Grouped by feature. Regenerated P-012.

# ─── Runtime & process ───────────────────────────────────────────────
# NODE_ENV=development
# PORT=3002
# TRUST_PROXY=false
# JSON_BODY_LIMIT=50mb
# UPLOAD_MAX_BYTES=209715200            # 200 MB (P-019)
# FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
# CORS_ALLOW_NO_ORIGIN=false
# VERCEL=                               # set automatically by Vercel

# ─── Rate limiting ───────────────────────────────────────────────────
# API_RATE_LIMIT_MAX=400
# AUTH_PREFLIGHT_BURST=20               # per-IP/min throttle for JWKS misses (P-031)

# ─── Azure AD JWT validation (server) ────────────────────────────────
# Must match client/client.env VITE_AZURE_* values.
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=

# ─── Dev-only auth bypass (P-009) ────────────────────────────────────
# DISABLE_AUTH=false
# AUTH_BYPASS_DEV_TOKEN=                 # required when DISABLE_AUTH=true

# ─── Azure OpenAI (chat + intent) ────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_INTENT_MODEL=
# INSIGHT_MODEL=
# INSIGHT_TEMPERATURE=0.2
# INSIGHT_TEMPERATURE_CONSERVATIVE=0.1
# INSIGHT_BATCH_TEMPERATURE=0.2

# ─── Azure OpenAI Embeddings (RAG) ───────────────────────────────────
# AZURE_OPENAI_EMBEDDING_ENDPOINT=
# AZURE_OPENAI_EMBEDDING_API_KEY=
# AZURE_OPENAI_EMBEDDING_API_VERSION=2024-10-21
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
# AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072   # must match Azure Search index vector field (P-007)

# ─── Azure AI Search (RAG) ──────────────────────────────────────────
# Create index: npm run create-rag-index
# Smoke check: npm run rag-smoke (optional RAG_SMOKE_SESSION_ID + RAG_SMOKE_QUERY)
# RAG_ENABLED=false
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_ADMIN_KEY=
# AZURE_SEARCH_INDEX_NAME=rag-session-chunks
# RAG_TOP_K=8
# RAG_SMOKE_SESSION_ID=
# RAG_SMOKE_QUERY=

# ─── Cosmos DB ──────────────────────────────────────────────────────
# COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
# COSMOS_KEY=
# COSMOS_DATABASE_ID=MaricoInsight
# COSMOS_CONTAINER_ID=ChatSessions
# COSMOS_DASHBOARDS_CONTAINER_ID=Dashboards
# COSMOS_SHARED_ANALYSES_CONTAINER_ID=SharedAnalyses
# COSMOS_SHARED_DASHBOARDS_CONTAINER_ID=SharedDashboards

# ─── Azure Blob Storage ─────────────────────────────────────────────
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
# AZURE_STORAGE_CONTAINER_NAME=maricoinsight

# ─── Snowflake (optional import source) ─────────────────────────────
# SNOWFLAKE_ACCOUNT=                    # e.g. zv14667.ap-south-1.aws
# SNOWFLAKE_USERNAME=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=                   # fully-qualified at query time; login uses empty
# SNOWFLAKE_SCHEMA=

# ─── Python data-ops bridge ─────────────────────────────────────────
# PYTHON_SERVICE_URL=http://localhost:8001
# PYTHON_SERVICE_API_KEY=                # required in production (P-037)

# ─── Upload & enrichment pipeline ───────────────────────────────────
# DATASET_PROFILE_TIMEOUT_MS=45000
# DISABLE_UPLOAD_INITIAL_ANALYSIS=false
# FAST_UPLOAD_SESSION_CONTEXT=true
# ENRICHMENT_DEBUG_LOGS=false
# ENABLE_DIRTY_DATE_LLM=false
# DIRTY_DATE_LLM_BATCH_SIZE=100
# DIRTY_DATE_MAX_UNIQUES=200
# LLM_DATE_OVERRIDE_PARSE_THRESHOLD=0.6
# CSV_MISMATCH_WARN_RATIO=0.05

# ─── Agentic loop (RAG mandatory when on) ───────────────────────────
# AGENTIC_LOOP_ENABLED=false
# AGENTIC_STRICT=false                  # deprecated when agentic is on
# AGENTIC_ALLOW_NO_RAG=false            # tests / local only; bypasses RAG assertion
# AGENT_MAX_STEPS=12
# AGENT_MAX_WALL_MS=120000
# AGENT_MAX_TOOL_CALLS=20
# AGENT_MAX_VERIFIER_ROUNDS_STEP=2
# AGENT_MAX_VERIFIER_ROUNDS_FINAL=2
# AGENT_MAX_REPLANS_PER_STEP=2          # P-020
# AGENT_MAX_LLM_CALLS=40
# AGENT_SAMPLE_ROWS_CAP=200
# AGENT_OBSERVATION_MAX_CHARS=8000
# AGENT_MAX_EXTRA_CHARTS_PER_TURN=2
# AGENT_MID_TURN_CONTEXT=true
# AGENT_MID_TURN_CONTEXT_THROTTLE_MS=8000
# AGENT_INTERMEDIATE_PIVOT_COALESCE=true
# AGENT_INTER_AGENT_MESSAGES=false
# AGENT_INTER_AGENT_PROMPT_FEEDBACK=false
# AGENT_SSE_CRITIC_FINAL_ONLY=true
# AGENT_VERBOSE_LOGS=false
# SIMPLE_ANALYSIS_FAST_PATH=true
# STREAM_CHAT_HARD_TIMEOUT_MS=150000    # wall-clock backstop for /chat/stream (P-008)

# ─── Phase-2 dashboard autogen (in-chat "build me a dashboard") ────
# DASHBOARD_AUTOGEN_ENABLED=false
#   Turns on buildDashboardFromTurn + the DashboardDraftCard preview.
#   REQUIRES AGENTIC_LOOP_ENABLED=true (startup fails fast otherwise:
#   the draft is emitted from runAgentTurn, so it is dead config
#   without the agent loop). Once enabled, the patch_dashboard agent
#   tool also becomes effective for follow-up edits.
#
# ─── Phase-1 deep-analysis skills ──────────────────────────────────
# DEEP_ANALYSIS_SKILLS_ENABLED=false
# DEEP_ANALYSIS_SKILL_ALLOWLIST=          # comma-separated, e.g. variance_decomposer,driver_discovery

# ─── Diagnostic ("deep dive") pipeline ──────────────────────────────
# DIAGNOSTIC_PIVOT_FILTER_MERGE_ENABLED=false
# DIAGNOSTIC_PIVOT_MERGE_MIN_CONFIDENCE=0.75
# DIAGNOSTIC_SLICE_ROW_CAP=100000
# DIAGNOSTIC_MAX_PARALLEL=3
# DIAGNOSTIC_COMPOSITE_TOOL_ENABLED=false
# DISABLE_TEMPORAL_FACETS=false

# ─── Logging ─────────────────────────────────────────────────────────
# ENABLE_SSE_LOGGING=false
