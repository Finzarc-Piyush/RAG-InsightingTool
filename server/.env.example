# Copy relevant lines into `server/server.env` (loaded by loadEnv.ts).
# Do not commit real secrets. Grouped by feature.
# Hand-maintained (no generator) — when you add a `process.env.X` read in
# server code, document X here in the matching section. SECURITY- and
# COST-relevant vars are flagged inline with [SECURITY] / [COST].

# ─── Runtime & process ───────────────────────────────────────────────
# NODE_ENV=development
# PORT=3002
# TRUST_PROXY=false
# JSON_BODY_LIMIT=50mb
# UPLOAD_MAX_BYTES=209715200            # 200 MB (P-019)
# FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
# CORS_ALLOW_NO_ORIGIN=false
# VERCEL=                               # set automatically by Vercel

# ─── Rate limiting ───────────────────────────────────────────────────
# API_RATE_LIMIT_MAX=400
# AUTH_PREFLIGHT_BURST=20               # per-IP/min throttle for JWKS misses (P-031)

# ─── Azure AD JWT validation (server) ────────────────────────────────
# Must match client/client.env VITE_AZURE_* values.
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=

# ─── Dev-only auth bypass (P-009) ────────────────────────────────────
# DISABLE_AUTH=false
# AUTH_BYPASS_DEV_TOKEN=                 # required when DISABLE_AUTH=true

# ─── Azure OpenAI (chat + intent) ────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_INTENT_MODEL=
# INSIGHT_MODEL=
# INSIGHT_TEMPERATURE=0.2
# INSIGHT_TEMPERATURE_CONSERVATIVE=0.1
# INSIGHT_BATCH_TEMPERATURE=0.2
# OPENAI_MODEL_PRIMARY=                  # [COST] primary deployment name; falls back to AZURE_OPENAI_DEPLOYMENT_NAME then "gpt-4o-mini"
# OPENAI_MODEL_MINI=                     # [COST] cheap-tier deployment for classifiers/quick-lookup; falls back to PRIMARY then "gpt-4o-mini"
# OPENAI_USE_MAX_COMPLETION_TOKENS=      # "true"/"false" — force the max_completion_tokens param (newer o-series) vs max_tokens; auto-detected per model when unset
# AZURE_OPENAI_MAX_RETRIES=5             # [COST] SDK retry attempts on a failed chat/embedding call (each retry re-bills tokens)

# ─── Anthropic Claude (W1 · multi-provider synthesis) ──────────────
# Selected automatically when a per-purpose model override starts with
# `claude-` (e.g. OPENAI_MODEL_FOR_NARRATOR=claude-opus-4-7). Falls back to
# Azure OpenAI when this key is absent.
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_VERSION=2023-06-01
# ANTHROPIC_MAX_CONCURRENCY=6            # max in-flight Anthropic requests (client-side semaphore) before queueing
#
# W2 · recommended synthesis routing — uncomment to send the narrator,
# verifier_deep, coordinator, and hypothesis stages to Claude Opus 4.7
# while keeping classifiers/planner on the cheaper Azure deployments.
# ANTHROPIC_API_KEY must be set for these to take effect; if it is missing
# the call throws and the calling stage surfaces a clear error.
# OPENAI_MODEL_FOR_NARRATOR=claude-opus-4-7
# OPENAI_MODEL_FOR_VERIFIER_DEEP=claude-opus-4-7
# OPENAI_MODEL_FOR_COORDINATOR=claude-opus-4-7
# OPENAI_MODEL_FOR_HYPOTHESIS=claude-opus-4-7
#
# [COST] OPENAI_MODEL_FOR_* is a GENERIC per-role routing family — any LLM call
# purpose in lib/agents/runtime/llmCallPurpose.ts can be overridden by
# OPENAI_MODEL_FOR_<PURPOSE> (e.g. _PLANNER, _REFLECTOR, _CLASSIFIER,
# _QUICK_LOOKUP_PLANNER). A `claude-*` value routes that role to Anthropic;
# any other value names an Azure deployment. Routing one role to Opus raises
# per-turn cost for that role only — leave unset to keep the Azure default.

# ─── Azure OpenAI Embeddings (RAG) ───────────────────────────────────
# AZURE_OPENAI_EMBEDDING_ENDPOINT=
# AZURE_OPENAI_EMBEDDING_API_KEY=
# AZURE_OPENAI_EMBEDDING_API_VERSION=2024-10-21
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
# AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072   # must match Azure Search index vector field (P-007)

# ─── Azure AI Search (RAG) ──────────────────────────────────────────
# Create index: npm run create-rag-index
# Smoke check: npm run rag-smoke (optional RAG_SMOKE_SESSION_ID + RAG_SMOKE_QUERY)
# RAG_ENABLED=false
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_ADMIN_KEY=
# AZURE_SEARCH_INDEX_NAME=rag-session-chunks
# RAG_TOP_K=8
# RAG_KEYWORD_FALLBACK_MIN_SIM=0.3       # min cosine sim below which RAG falls back to keyword search
# RAG_SMOKE_SESSION_ID=
# RAG_SMOKE_QUERY=
#
# Past-analyses recall index (cross-session memory of prior answers)
# PAST_ANALYSES_INDEX_ENABLED=true       # set "false" to disable indexing/recall of past analyses
# AZURE_SEARCH_PAST_ANALYSES_INDEX_NAME=past-analyses

# ─── Cosmos DB ──────────────────────────────────────────────────────
# COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
# COSMOS_KEY=
# COSMOS_DATABASE_ID=MaricoInsight
# COSMOS_CONTAINER_ID=ChatSessions
# COSMOS_DASHBOARDS_CONTAINER_ID=Dashboards
# COSMOS_SHARED_ANALYSES_CONTAINER_ID=SharedAnalyses
# COSMOS_SHARED_DASHBOARDS_CONTAINER_ID=SharedDashboards
# Additional containers (defaults shown; created lazily on first write):
# COSMOS_PAST_ANALYSES_CONTAINER_ID=past_analyses             # cross-session past-analysis recall store
# COSMOS_ANALYSIS_MEMORY_CONTAINER_ID=analysis_memory         # durable per-session analytical memory
# COSMOS_DATASET_PROFILE_CACHE_CONTAINER_ID=dataset_profiles  # cached dataset profiles (skip re-profiling)
# COSMOS_DATASET_DIRECTIVES_CONTAINER_ID=dataset_directives   # per-dataset user directives/overrides
# COSMOS_DOMAIN_CONTEXT_TOGGLES_CONTAINER_ID=domain_context_toggles  # per-tenant domain-context toggles
# COSMOS_AUTOMATIONS_CONTAINER_ID=automations                 # saved scheduled automations
# COSMOS_LLM_USAGE_CONTAINER_ID=llm_usage           # [COST] per-call LLM token/cost telemetry
# COSMOS_USAGE_EVENTS_CONTAINER_ID=usage_events     # [COST] product usage events (USAGE_EVENTS_ENABLED)
# COSMOS_USER_BUDGET_CONTAINER_ID=user_budget       # [COST] per-user budget/quota accounting (budget gate)
# COSMOS_COST_ALERTS_CONTAINER_ID=cost_alerts       # [COST] per-turn cost-alert records (COST_ALERT_PER_TURN_USD)

# ─── Azure Blob Storage ─────────────────────────────────────────────
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
# AZURE_STORAGE_CONTAINER_NAME=maricoinsight

# ─── Snowflake (optional import source) ─────────────────────────────
# SNOWFLAKE_ACCOUNT=                    # e.g. zv14667.ap-south-1.aws
# SNOWFLAKE_USERNAME=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=                   # fully-qualified at query time; login uses empty
# SNOWFLAKE_SCHEMA=

# ─── Python data-ops bridge ─────────────────────────────────────────
# PYTHON_SERVICE_URL=http://localhost:8001
# PYTHON_SERVICE_API_KEY=                # required in production (P-037)

# ─── Upload & enrichment pipeline ───────────────────────────────────
# DATASET_PROFILE_TIMEOUT_MS=45000
# DATASET_PROFILE_SAMPLE_ROWS=60         # rows sampled per column when profiling a freshly uploaded dataset
# INDICATOR_ENRICH_TIMEOUT_MS=20000      # per-call timeout for the LLM column-indicator enrichment step
# LARGE_FILE_COERCION_ENABLED=false      # "true" enables aggressive type coercion on large files (memory/CPU tradeoff)
# DISABLE_UPLOAD_INITIAL_ANALYSIS=false
# FAST_UPLOAD_SESSION_CONTEXT=true
# ENRICHMENT_DEBUG_LOGS=false
# ENABLE_DIRTY_DATE_LLM=false
# DIRTY_DATE_LLM_BATCH_SIZE=100
# DIRTY_DATE_MAX_UNIQUES=200
# LLM_DATE_OVERRIDE_PARSE_THRESHOLD=0.6
# CSV_MISMATCH_WARN_RATIO=0.05
# WIDE_FORMAT_AUTO_MELT_ENABLED=true     # default ON; "false"/"0" disables auto-melting wide (pivoted) sheets to long form

# ─── Query engine (DuckDB read path) ────────────────────────────────
# USE_PARQUET_READ_PATH=false            # [COST] "true" reads dataset from Parquet instead of CSV (faster/cheaper scans, requires Parquet conversion)

# ─── Agentic loop (RAG mandatory when on) ───────────────────────────
# AGENTIC_LOOP_ENABLED=false
# AGENTIC_STRICT=false                  # deprecated when agentic is on
# AGENTIC_ALLOW_NO_RAG=false            # tests / local only; bypasses RAG assertion
# AGENT_MAX_STEPS=12
# AGENT_MAX_WALL_MS=120000
# AGENT_MAX_TOOL_CALLS=20
# AGENT_MAX_VERIFIER_ROUNDS_STEP=2
# AGENT_MAX_VERIFIER_ROUNDS_FINAL=2
# AGENT_MAX_REPLANS_PER_STEP=2          # P-020
# AGENT_MAX_LLM_CALLS=40
# AGENT_SAMPLE_ROWS_CAP=200
# AGENT_OBSERVATION_MAX_CHARS=8000
# AGENT_MAX_EXTRA_CHARTS_PER_TURN=2
# AGENT_MAX_FINAL_CHARTS_PER_TURN=24     # hard cap on charts attached to a final answer envelope
# AGENT_MAGNITUDE_AUDIT_MAX=10           # max numeric magnitudes cross-checked against source rows per turn
# AGENT_CHART_INTENT_GUARD=true          # default ON; "false" disables the guard that suppresses charts on non-visual asks
# AGENT_PROMOTE_INTERMEDIATE_CHARTS=true # default ON; "false" stops promoting mid-turn charts into the final answer
# AGENT_DECOMPOSITION_ENABLED=false      # "true" lets the planner decompose a multi-part question into sub-steps
# AGENT_INFER_NEGATIVE_FILTERS=true      # default ON; "false" disables inferring "exclude X" filters from phrasing
# AGENT_IMMUTABLE_CTX_DATA=true          # default ON; "false" allows tools to mutate shared context data (debug only)
# AGENT_COALESCE_SAME_SHAPE_QUERIES=true # default ON; "false" disables deduping identically-shaped DuckDB queries
# AGENT_CHECKPOINT_DEBOUNCE_MS=3000      # min interval between per-turn checkpoint writes to Cosmos
# AGENT_MID_TURN_CONTEXT=true
# AGENT_MID_TURN_CONTEXT_THROTTLE_MS=8000
# AGENT_INTERMEDIATE_PIVOT_COALESCE=true
# AGENT_INTER_AGENT_MESSAGES=false
# AGENT_INTER_AGENT_PROMPT_FEEDBACK=false
# AGENT_SSE_CRITIC_FINAL_ONLY=true
# AGENT_VERBOSE_LOGS=false
# SIMPLE_ANALYSIS_FAST_PATH=true
# STREAM_CHAT_HARD_TIMEOUT_MS=150000    # wall-clock backstop for /chat/stream (P-008)

# ─── Wave QL1 · Quick-lookup fast path ─────────────────────────────
# QUICK_LOOKUP_ENABLED=true             # default ON; set "false" to force
#   every question through the full agentic loop (rollback).
#   When ON, lookup-shape questions ("top 10 X by Y", "list customers in Z",
#   "how many orders last month", "average price by category") bypass the
#   hypothesis → brief → planner → reflector → narrator → verifier pipeline
#   with one Mini-tier LLM call + one DuckDB query. Output is the preview
#   table + 3 deterministic suggested follow-up chips.
#   Detector regex/heuristic rejects analytical-intent keywords (why,
#   compare, trend, driver, breakdown, …) so misroutes are near zero.
#   On ANY planner/execute/validation failure (Zod fail, zero rows, …),
#   the fast path returns null and the full agentic loop runs unchanged.
# OPENAI_MODEL_FOR_QUICK_LOOKUP_PLANNER=          # per-purpose override.
#   Defaults to the MINI tier (`OPENAI_MODEL_MINI` or `gpt-4o-mini`).

# ─── Phase-2 dashboard autogen (in-chat "build me a dashboard") ────
# DASHBOARD_AUTOGEN_ENABLED=false
# DASHBOARD_AUTOGEN_ROLLOUT_PCT=100      # % of eligible users the autogen offer is shown to (0–100; default 100 when enabled)
#   Turns on buildDashboardFromTurn + the DashboardDraftCard preview.
#   REQUIRES AGENTIC_LOOP_ENABLED=true (startup fails fast otherwise:
#   the draft is emitted from runAgentTurn, so it is dead config
#   without the agent loop). Once enabled, the patch_dashboard agent
#   tool also becomes effective for follow-up edits.
#
# ─── Phase-1 deep-analysis skills ──────────────────────────────────
# DEEP_ANALYSIS_SKILLS_ENABLED=false
# DEEP_ANALYSIS_SKILL_ALLOWLIST=          # comma-separated, e.g. variance_decomposer,driver_discovery

# ─── Diagnostic ("deep dive") pipeline ──────────────────────────────
# DIAGNOSTIC_PIVOT_FILTER_MERGE_ENABLED=false
# DIAGNOSTIC_PIVOT_MERGE_MIN_CONFIDENCE=0.75
# DIAGNOSTIC_SLICE_ROW_CAP=100000
# DIAGNOSTIC_MAX_PARALLEL=3
# DIAGNOSTIC_COMPOSITE_TOOL_ENABLED=false
# DISABLE_TEMPORAL_FACETS=false

# ─── W14 · Web search tool (planner-callable, env-gated) ───────────
# WEB_SEARCH_ENABLED=false        # set "true" to let the planner call web_search
# WEB_SEARCH_PROVIDER=auto        # auto | tavily | … — selects the web-search backend (default auto)
# TAVILY_API_KEY=                 # required when WEB_SEARCH_ENABLED=true
#   Adds open-web context (benchmarks, peer/competitor data, market news)
#   for questions the user's uploaded data alone can't answer. Tool is
#   registered unconditionally so the planner sees the manifest even when
#   disabled — disabled invocations return a clear no-op message so the
#   planner learns to stop calling it. Default provider is Tavily; swap
#   in another by editing tools/webSearchTool.ts.

# ─── W28 · Live-LLM golden-replay test gate ────────────────────────
# LIVE_LLM_REPLAY=false
#   Set "true" together with a valid AZURE_OPENAI_API_KEY (and optional
#   AGENTIC_ALLOW_NO_RAG=true) to enable the W28 golden-replay tests in
#   `tests/liveLlmGoldenReplayW28.test.ts`. Tests run the real agent
#   pipeline against curated FMCG fixtures and assert SHAPE only (no
#   exact-text matches). Cost ~$3 per replay run; intended for nightly
#   CI or pre-release smoke, NOT per-commit. When unset, the tests
#   record as 1 trivially-passing skip and add no cost.
# RECORD_LIVE_LLM_BASELINE=false
#   W33 · when set together with LIVE_LLM_REPLAY=true, each fixture
#   dumps its full result envelope to
#   `tests/fixtures/golden-replay/<id>.recorded.json` (gitignored)
#   and assertions soften to "answer non-empty" so the test passes
#   on capture. Operators inspect the recordings to inform tighter
#   assertions in future waves. See
#   `tests/fixtures/golden-replay/README.md` for the workflow.

# ─── W39 · Merged pre-planner LLM call (cost / latency cut) ────────
# MERGED_PRE_PLANNER=false
#   When true, the agent loop merges the pre-planner `analysisBrief`
#   and `hypothesisPlanner` calls into a single LLM round-trip. Cuts
#   ~one network round-trip and 30–40% of pre-planner tokens per
#   analytical turn. Falls back to per-task calls on any failure
#   (parse error, schema mismatch, network), so the merged option is
#   strictly safer than the per-task path. Default off — opt-in for
#   A/B once telemetry shows it produces equivalent quality.

# ─── W38 · Streaming narrator output (perceived-latency cut) ───────
# STREAMING_NARRATOR_ENABLED=false
#   When true, the agent loop's initial narrator call uses
#   `completeJsonStreaming` and forwards each chunk's delta to the client
#   via `answer_chunk` SSE events. The client accumulates these into
#   `streamingNarratorPreview` for live "drafting answer…" UX. Repair
#   calls (W17/W22) stay non-streaming because the user already saw the
#   initial draft. Falls back to non-streaming on any failure (network,
#   parse, schema). Default off — opt-in until UX surface lands.

# ─── W19 · Per-step LLM-enriched workbench insights ────────────────
# RICH_STEP_INSIGHTS_ENABLED=false
#   When true, fires ONE extra LLM call at end of turn that ties each
#   workbench step to the analysis arc (1–2 sentence interpretive
#   commentary on top of the W10 deterministic first-sentence
#   extraction). Adds ~2–5s of latency per turn. Default off — opt-in
#   for power users / demo flows. Uses the cheap insight model
#   (`getInsightModel`); no separate key required.

# ─── Logging ─────────────────────────────────────────────────────────
# ENABLE_SSE_LOGGING=false
# LOG_LEVEL=debug
#   Threshold for the general logger (error|warn|info|debug). Default debug
#   (emits everything). Production should set `info` to cut noise. (lib/logger.ts)
# LOG_FORMAT=
#   `json` → structured JSON log lines stamped with traceId/sessionId/userId;
#   `text` → plain console passthrough. Default: json in production/Vercel, text
#   otherwise. (EX4 / OBS-1, lib/logger.ts)

# ─── Security / auth ─────────────────────────────────────────────────
# ALLOW_JWT_QUERY=false
#   When true, accepts the access token via ?access_token= query param (in
#   addition to the Authorization header). Relaxation — leave unset in prod
#   unless required by a streaming client. (middleware/azureAdAuth.ts)
# SUPERADMIN_EMAILS=
#   Comma-separated emails MERGED with the hardcoded superadmin allowlist
#   (rotatable without a deploy). Prefer SUPERADMIN_OIDS (immutable). (CFG-3, lib/superadmin.ts)

# ─── Cost / quota gate ───────────────────────────────────────────────
# BUDGET_GATE_ENFORCEMENT=warn_only
#   off | warn_only | enforce. Default warn_only (accounting + X-Budget-* headers,
#   no rejection). Production should set `enforce`. (SEC-4, middleware/budgetGate.ts)
# DAILY_QUESTION_QUOTA=20
#   Per-user/day question cap used when the gate is in enforce mode.

# ─── Observability ───────────────────────────────────────────────────
# SENTRY_DSN=
#   When set, server errors are forwarded to Sentry via the terminal error
#   handler. (lib/observability/crashReporter.ts)
# SENTRY_TRACES_SAMPLE_RATE=0
#   Fraction (0–1) of requests sampled for Sentry performance tracing. Default 0 (off).
# SSE_VALIDATE=1
#   "0" disables runtime Zod validation of outgoing SSE event payloads (perf escape hatch). Default on.

# ─── Cosmos resilience (RESIL-2) ─────────────────────────────────────
# COSMOS_REQUEST_TIMEOUT_MS=30000      # per-request timeout for the Cosmos SDK
# COSMOS_MAX_RETRY_ATTEMPTS=9          # SDK throttling/transient retry attempts
# COSMOS_MAX_RETRY_WAIT_SEC=30         # cap on cumulative SDK retry wait

# ─── Data-ops expression sandbox (PY-6, python-service) ──────────────
# ASTEVAL_MAX_TIME_SEC=5
#   Max wall-clock seconds for an LLM-generated derived-column expression
#   (asteval). Bounds a pathological expression. (python-service/data_operations.py)

# ─── Analytical feature flags (planner-callable analyses) ────────────
# Each gates an extra analysis the planner may run; off keeps turns cheaper.
# ANOMALY_DETECTION_ENABLED=false        # "true" enables anomaly/outlier detection analysis
# FORECAST_ENABLED=false                 # "true" enables time-series forecasting analysis
# SIGNIFICANCE_TESTS_ENABLED=false       # "true" enables statistical significance testing
# BUSINESS_ACTIONS_ENABLED=             # business-action recommendations (default per FEATURE_FLAGS registry)
# AUTO_ATTACH_LAYERS_ENABLED=true        # default ON; "false"/"0" stops auto-attaching related data layers
# EXHAUSTIVE_BREADTH_ENABLED=false       # [COST] "true"/"1" widens breadth sweeps (more tool/LLM calls per turn)
# DIRECT_ANSWER_ENABLED=false            # "true" allows a direct-answer shortcut for trivially factual asks

# ─── LLM usage / cost telemetry ──────────────────────────────────────
# LLM_USAGE_TELEMETRY_ENABLED=true       # [COST] default ON; "false" stops writing per-call LLM token/cost records (COSMOS_LLM_USAGE_CONTAINER_ID)
# USAGE_EVENTS_ENABLED=true              # [COST] default ON; "false" stops writing product usage events (COSMOS_USAGE_EVENTS_CONTAINER_ID)
# COST_ALERT_PER_TURN_USD=2.0            # [COST] per-turn spend threshold that records a cost alert (must be > 0; default 2.0)

# ─── Question cache (skip re-answering repeat/near-duplicate asks) ───
# QUESTION_CACHE_EXACT_ENABLED=false     # [COST] "true" serves byte-identical repeat questions from cache (skips the LLM)
# QUESTION_CACHE_SEMANTIC_ENABLED=false  # [COST] "true" serves near-duplicate questions above the similarity threshold
# QUESTION_CACHE_SIM_THRESHOLD=0.92      # cosine-sim cutoff for a semantic cache hit (0–1; default 0.92)
# QUESTION_CACHE_TTL_DAYS=7              # cached-answer lifetime in days (must be > 0; default 7)

# ─── Deep investigation (multi-node investigation tree) ──────────────
# [COST] Fans a question into a tree of sub-investigations — high token/latency.
# Re-wiring it into the live flow needs a feature flag (invariant #6); off by default.
# DEEP_INVESTIGATION_ENABLED=false       # master switch for the deep-investigation path
# DEEP_INVESTIGATION_MAX_NODES=15        # total nodes across the whole tree
# DEEP_INVESTIGATION_MAX_DEPTH=3         # max tree depth
# DEEP_INVESTIGATION_MAX_CHILDREN=3      # max children per node
# DEEP_INVESTIGATION_MAX_PARALLEL=3      # max nodes investigated concurrently
# DEEP_INVESTIGATION_MAX_LLM_CALLS=120   # [COST] LLM-call ceiling across the whole tree
# DEEP_INVESTIGATION_MAX_WALL_MS=1500000 # whole-tree wall-clock budget (25 min)
# DEEP_INVESTIGATION_PER_NODE_LLM=12     # [COST] LLM-call ceiling per node
# DEEP_INVESTIGATION_PER_NODE_WALL_MS=90000  # per-node wall-clock budget

# ─── Spawned follow-ups ("investigating further" chips) ──────────────
# [COST] Auto-investigates spawned follow-up questions in the background.
# SPAWNED_FOLLOWUP_ENABLED=false         # "true"/"1" auto-runs spawned follow-up sub-investigations
# SPAWNED_FOLLOWUP_PARALLEL=2            # max follow-ups investigated concurrently
# SPAWNED_FOLLOWUP_MAX_LLM_CALLS=60      # [COST] total LLM-call ceiling across all follow-ups in a turn
# SPAWNED_FOLLOWUP_MAX_WALL_MS=120000    # total wall-clock budget across follow-ups
# SPAWNED_FOLLOWUP_PER_SUB_LLM=8         # [COST] LLM-call ceiling per follow-up
# SPAWNED_FOLLOWUP_PER_SUB_STEPS=6       # plan-step ceiling per follow-up
# SPAWNED_FOLLOWUP_PER_SUB_TOOL_CALLS=15 # tool-call ceiling per follow-up
# SPAWNED_FOLLOWUP_PER_SUB_WALL_MS=60000 # per-follow-up wall-clock budget

# ─── Deprecated / legacy (kept for test compatibility only) ──────────
# ADMIN_EMAILS=
#   RETIRED — no longer consulted for production access (hardcoded superadmin
#   gate replaced it; see lib/superadmin.ts + SUPERADMIN_EMAILS above). Read
#   only by legacy tests. Do NOT rely on it to grant admin access.
