# Copy relevant lines into `server/server.env` (loaded by loadEnv.ts).
# Do not commit real secrets. Grouped by feature. Regenerated P-012.

# ─── Runtime & process ───────────────────────────────────────────────
# NODE_ENV=development
# PORT=3002
# TRUST_PROXY=false
# JSON_BODY_LIMIT=50mb
# UPLOAD_MAX_BYTES=209715200            # 200 MB (P-019)
# FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
# CORS_ALLOW_NO_ORIGIN=false
# VERCEL=                               # set automatically by Vercel

# ─── Rate limiting ───────────────────────────────────────────────────
# API_RATE_LIMIT_MAX=400
# AUTH_PREFLIGHT_BURST=20               # per-IP/min throttle for JWKS misses (P-031)

# ─── Azure AD JWT validation (server) ────────────────────────────────
# Must match client/client.env VITE_AZURE_* values.
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=

# ─── Dev-only auth bypass (P-009) ────────────────────────────────────
# DISABLE_AUTH=false
# AUTH_BYPASS_DEV_TOKEN=                 # required when DISABLE_AUTH=true

# ─── Azure OpenAI (chat + intent) ────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_INTENT_MODEL=
# INSIGHT_MODEL=
# INSIGHT_TEMPERATURE=0.2
# INSIGHT_TEMPERATURE_CONSERVATIVE=0.1
# INSIGHT_BATCH_TEMPERATURE=0.2

# ─── Anthropic Claude (W1 · multi-provider synthesis) ──────────────
# Selected automatically when a per-purpose model override starts with
# `claude-` (e.g. OPENAI_MODEL_FOR_NARRATOR=claude-opus-4-7). Falls back to
# Azure OpenAI when this key is absent.
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_VERSION=2023-06-01
#
# W2 · recommended synthesis routing — uncomment to send the narrator,
# verifier_deep, coordinator, and hypothesis stages to Claude Opus 4.7
# while keeping classifiers/planner on the cheaper Azure deployments.
# ANTHROPIC_API_KEY must be set for these to take effect; if it is missing
# the call throws and the calling stage surfaces a clear error.
# OPENAI_MODEL_FOR_NARRATOR=claude-opus-4-7
# OPENAI_MODEL_FOR_VERIFIER_DEEP=claude-opus-4-7
# OPENAI_MODEL_FOR_COORDINATOR=claude-opus-4-7
# OPENAI_MODEL_FOR_HYPOTHESIS=claude-opus-4-7

# ─── Azure OpenAI Embeddings (RAG) ───────────────────────────────────
# AZURE_OPENAI_EMBEDDING_ENDPOINT=
# AZURE_OPENAI_EMBEDDING_API_KEY=
# AZURE_OPENAI_EMBEDDING_API_VERSION=2024-10-21
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
# AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072   # must match Azure Search index vector field (P-007)

# ─── Azure AI Search (RAG) ──────────────────────────────────────────
# Create index: npm run create-rag-index
# Smoke check: npm run rag-smoke (optional RAG_SMOKE_SESSION_ID + RAG_SMOKE_QUERY)
# RAG_ENABLED=false
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_ADMIN_KEY=
# AZURE_SEARCH_INDEX_NAME=rag-session-chunks
# RAG_TOP_K=8
# RAG_SMOKE_SESSION_ID=
# RAG_SMOKE_QUERY=

# ─── Cosmos DB ──────────────────────────────────────────────────────
# COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
# COSMOS_KEY=
# COSMOS_DATABASE_ID=MaricoInsight
# COSMOS_CONTAINER_ID=ChatSessions
# COSMOS_DASHBOARDS_CONTAINER_ID=Dashboards
# COSMOS_SHARED_ANALYSES_CONTAINER_ID=SharedAnalyses
# COSMOS_SHARED_DASHBOARDS_CONTAINER_ID=SharedDashboards

# ─── Azure Blob Storage ─────────────────────────────────────────────
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
# AZURE_STORAGE_CONTAINER_NAME=maricoinsight

# ─── Snowflake (optional import source) ─────────────────────────────
# SNOWFLAKE_ACCOUNT=                    # e.g. zv14667.ap-south-1.aws
# SNOWFLAKE_USERNAME=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=                   # fully-qualified at query time; login uses empty
# SNOWFLAKE_SCHEMA=

# ─── Python data-ops bridge ─────────────────────────────────────────
# PYTHON_SERVICE_URL=http://localhost:8001
# PYTHON_SERVICE_API_KEY=                # required in production (P-037)

# ─── Upload & enrichment pipeline ───────────────────────────────────
# DATASET_PROFILE_TIMEOUT_MS=45000
# DISABLE_UPLOAD_INITIAL_ANALYSIS=false
# FAST_UPLOAD_SESSION_CONTEXT=true
# ENRICHMENT_DEBUG_LOGS=false
# ENABLE_DIRTY_DATE_LLM=false
# DIRTY_DATE_LLM_BATCH_SIZE=100
# DIRTY_DATE_MAX_UNIQUES=200
# LLM_DATE_OVERRIDE_PARSE_THRESHOLD=0.6
# CSV_MISMATCH_WARN_RATIO=0.05

# ─── Agentic loop (RAG mandatory when on) ───────────────────────────
# AGENTIC_LOOP_ENABLED=false
# AGENTIC_STRICT=false                  # deprecated when agentic is on
# AGENTIC_ALLOW_NO_RAG=false            # tests / local only; bypasses RAG assertion
# AGENT_MAX_STEPS=12
# AGENT_MAX_WALL_MS=120000
# AGENT_MAX_TOOL_CALLS=20
# AGENT_MAX_VERIFIER_ROUNDS_STEP=2
# AGENT_MAX_VERIFIER_ROUNDS_FINAL=2
# AGENT_MAX_REPLANS_PER_STEP=2          # P-020
# AGENT_MAX_LLM_CALLS=40
# AGENT_SAMPLE_ROWS_CAP=200
# AGENT_OBSERVATION_MAX_CHARS=8000
# AGENT_MAX_EXTRA_CHARTS_PER_TURN=2
# AGENT_MID_TURN_CONTEXT=true
# AGENT_MID_TURN_CONTEXT_THROTTLE_MS=8000
# AGENT_INTERMEDIATE_PIVOT_COALESCE=true
# AGENT_INTER_AGENT_MESSAGES=false
# AGENT_INTER_AGENT_PROMPT_FEEDBACK=false
# AGENT_SSE_CRITIC_FINAL_ONLY=true
# AGENT_VERBOSE_LOGS=false
# SIMPLE_ANALYSIS_FAST_PATH=true
# STREAM_CHAT_HARD_TIMEOUT_MS=150000    # wall-clock backstop for /chat/stream (P-008)

# ─── Phase-2 dashboard autogen (in-chat "build me a dashboard") ────
# DASHBOARD_AUTOGEN_ENABLED=false
#   Turns on buildDashboardFromTurn + the DashboardDraftCard preview.
#   REQUIRES AGENTIC_LOOP_ENABLED=true (startup fails fast otherwise:
#   the draft is emitted from runAgentTurn, so it is dead config
#   without the agent loop). Once enabled, the patch_dashboard agent
#   tool also becomes effective for follow-up edits.
#
# ─── Phase-1 deep-analysis skills ──────────────────────────────────
# DEEP_ANALYSIS_SKILLS_ENABLED=false
# DEEP_ANALYSIS_SKILL_ALLOWLIST=          # comma-separated, e.g. variance_decomposer,driver_discovery

# ─── Diagnostic ("deep dive") pipeline ──────────────────────────────
# DIAGNOSTIC_PIVOT_FILTER_MERGE_ENABLED=false
# DIAGNOSTIC_PIVOT_MERGE_MIN_CONFIDENCE=0.75
# DIAGNOSTIC_SLICE_ROW_CAP=100000
# DIAGNOSTIC_MAX_PARALLEL=3
# DIAGNOSTIC_COMPOSITE_TOOL_ENABLED=false
# DISABLE_TEMPORAL_FACETS=false

# ─── W14 · Web search tool (planner-callable, env-gated) ───────────
# WEB_SEARCH_ENABLED=false        # set "true" to let the planner call web_search
# TAVILY_API_KEY=                 # required when WEB_SEARCH_ENABLED=true
#   Adds open-web context (benchmarks, peer/competitor data, market news)
#   for questions the user's uploaded data alone can't answer. Tool is
#   registered unconditionally so the planner sees the manifest even when
#   disabled — disabled invocations return a clear no-op message so the
#   planner learns to stop calling it. Default provider is Tavily; swap
#   in another by editing tools/webSearchTool.ts.

# ─── W28 · Live-LLM golden-replay test gate ────────────────────────
# LIVE_LLM_REPLAY=false
#   Set "true" together with a valid AZURE_OPENAI_API_KEY (and optional
#   AGENTIC_ALLOW_NO_RAG=true) to enable the W28 golden-replay tests in
#   `tests/liveLlmGoldenReplayW28.test.ts`. Tests run the real agent
#   pipeline against curated FMCG fixtures and assert SHAPE only (no
#   exact-text matches). Cost ~$3 per replay run; intended for nightly
#   CI or pre-release smoke, NOT per-commit. When unset, the tests
#   record as 1 trivially-passing skip and add no cost.
# RECORD_LIVE_LLM_BASELINE=false
#   W33 · when set together with LIVE_LLM_REPLAY=true, each fixture
#   dumps its full result envelope to
#   `tests/fixtures/golden-replay/<id>.recorded.json` (gitignored)
#   and assertions soften to "answer non-empty" so the test passes
#   on capture. Operators inspect the recordings to inform tighter
#   assertions in future waves. See
#   `tests/fixtures/golden-replay/README.md` for the workflow.

# ─── W39 · Merged pre-planner LLM call (cost / latency cut) ────────
# MERGED_PRE_PLANNER=false
#   When true, the agent loop merges the pre-planner `analysisBrief`
#   and `hypothesisPlanner` calls into a single LLM round-trip. Cuts
#   ~one network round-trip and 30–40% of pre-planner tokens per
#   analytical turn. Falls back to per-task calls on any failure
#   (parse error, schema mismatch, network), so the merged option is
#   strictly safer than the per-task path. Default off — opt-in for
#   A/B once telemetry shows it produces equivalent quality.

# ─── W38 · Streaming narrator output (perceived-latency cut) ───────
# STREAMING_NARRATOR_ENABLED=false
#   When true, the agent loop's initial narrator call uses
#   `completeJsonStreaming` and forwards each chunk's delta to the client
#   via `answer_chunk` SSE events. The client accumulates these into
#   `streamingNarratorPreview` for live "drafting answer…" UX. Repair
#   calls (W17/W22) stay non-streaming because the user already saw the
#   initial draft. Falls back to non-streaming on any failure (network,
#   parse, schema). Default off — opt-in until UX surface lands.

# ─── W19 · Per-step LLM-enriched workbench insights ────────────────
# RICH_STEP_INSIGHTS_ENABLED=false
#   When true, fires ONE extra LLM call at end of turn that ties each
#   workbench step to the analysis arc (1–2 sentence interpretive
#   commentary on top of the W10 deterministic first-sentence
#   extraction). Adds ~2–5s of latency per turn. Default off — opt-in
#   for power users / demo flows. Uses the cheap insight model
#   (`getInsightModel`); no separate key required.

# ─── Logging ─────────────────────────────────────────────────────────
# ENABLE_SSE_LOGGING=false
