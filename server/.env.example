# Copy relevant lines into `server.env` in this directory (see loadEnv.ts). Do not commit real secrets.

# HTTP port for the API (default 3003). If you change it, set the same port in client/client.env as VITE_DEV_API_PORT
# or VITE_DEV_API_ORIGIN so Vite’s /api proxy still reaches the server.

# Azure AD JWT validation (same tenant + app id as VITE_AZURE_* in client/client.env)
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=

# Local Python data-ops service
# PYTHON_SERVICE_URL=http://localhost:8001

# Initial upload: dataset profile LLM + session context seed LLM on sample/summary (no upload-time charts/insights).
# DATASET_PROFILE_TIMEOUT_MS=45000

# Skip upload-time LLM (profile + session context seed); enrichment still marked complete so chat is not blocked.
# DISABLE_UPLOAD_INITIAL_ANALYSIS=false

# RAG — create index first: npm run create-rag-index
# Smoke check: npm run rag-smoke  (optional: RAG_SMOKE_SESSION_ID=... RAG_SMOKE_QUERY=...)
# RAG_ENABLED=false
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_ADMIN_KEY=
# AZURE_SEARCH_INDEX_NAME=rag-session-chunks
# AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072
# RAG_TOP_K=8

# Agent loop (structured working memory + dependsOn step ordering — see lib/agents/runtime/workingMemory.ts)
# AGENTIC_LOOP_ENABLED=false
# With AGENTIC_LOOP_ENABLED=true: skip handler orchestrator and legacy dataAnalyzer fallbacks (fail closed on agent error/empty).
# AGENTIC_STRICT=false
# AGENT_MAX_STEPS=12
# AGENT_MAX_TOOL_CALLS=20
