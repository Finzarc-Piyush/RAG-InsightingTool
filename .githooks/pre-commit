#!/usr/bin/env bash
# Pre-commit — local enforcement of the cold-start gates, so doc/code drift is
# caught at commit time on a branch, not only by CI-on-push-to-main. Enable with
#   git config core.hooksPath .githooks
# Bypass in an emergency with  git commit --no-verify.
#
# Fast (<2s) and conservative: only the HARD, low-false-positive gates block.
# The symbol index (volatile line numbers) is warn-only and never blocks.
set -u

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$ROOT" || exit 0

# Degrade gracefully if the toolchain isn't on PATH (e.g. GUI commit).
if ! command -v npm >/dev/null 2>&1; then
  echo "pre-commit: npm not on PATH — skipping cold-start gates." >&2
  exit 0
fi

fail=0

echo "pre-commit • invariant firewall…"
if ! npm --prefix server run --silent check:invariants >/dev/null 2>&1; then
  echo "  ✗ invariant drift — run: npm --prefix server run check:invariants" >&2
  fail=1
fi

echo "pre-commit • doc references…"
if ! npm --prefix server run --silent check:doc-refs >/dev/null 2>&1; then
  echo "  ✗ a live doc references a file/symbol that doesn't exist — run: npm --prefix server run check:doc-refs" >&2
  fail=1
fi

echo "pre-commit • registry manifest fresh…"
# `registries.generated.md` is a GENERATED artifact (CLAUDE.md invariant #8 —
# "never hand-edit"). Its generator is deterministic + environment-stable
# (sorted, relative paths, no timestamps), so any change reflects a real
# tools/routes/skills edit. During tiny-wave development that change happens on
# most commits — so AUTO-STAGE the refreshed copy into THIS commit instead of
# blocking. The old "regenerated; now stage it yourself + re-commit" dance
# tripped on nearly every commit and compounded (a stale manifest left in the
# index re-blocked every later commit). Only a generator FAILURE blocks now.
if ! npm --prefix server run --silent gen:registries >/dev/null 2>&1; then
  echo "  ✗ gen:registries failed — run: npm --prefix server run gen:registries" >&2
  fail=1
elif ! git diff --quiet -- docs/index/registries.generated.md 2>/dev/null; then
  git add docs/index/registries.generated.md
  echo "  ↻ registries.generated.md refreshed + auto-staged (tools/routes/skills changed)" >&2
fi

if [ "$fail" -ne 0 ]; then
  echo "✗ pre-commit blocked. Fix the above, or bypass with: git commit --no-verify" >&2
  exit 1
fi
echo "✓ cold-start gates pass"
exit 0
