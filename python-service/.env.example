# python-service configuration (copy to .env; loaded from the process env).
# All values shown are defaults — uncomment + change to override.

# ─── Server ──────────────────────────────────────────────────────────
# PYTHON_SERVICE_HOST=0.0.0.0
# PYTHON_SERVICE_PORT=8001

# ─── Auth (REQUIRED in production) ───────────────────────────────────
# Shared secret the Node tier must send as X-Internal-Api-Key (constant-time
# compared). The service refuses to start in production without it.
# PYTHON_SERVICE_API_KEY=

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated allowed origins.
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ─── Limits / memory ─────────────────────────────────────────────────
# REQUEST_TIMEOUT=300          # seconds; also caps the MMM training gate
# MAX_ROWS=1000000             # hard cap on rows processed per request
# MAX_PREVIEW_ROWS=10000       # rows returned in a preview
# PYTHON_SERVICE_MAX_BODY_BYTES=52428800   # 50 MB request-body limit

# ─── Derived-column expression sandbox (PY-6) ────────────────────────
# ASTEVAL_MAX_TIME_SEC=5       # max wall-clock for an LLM-generated expression
